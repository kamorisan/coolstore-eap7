embed-server --std-out=echo --server-config=standalone-openshift.xml

if (outcome != success) of /subsystem=messaging-activemq/server=default/jms-topic=orders:read-resource
    /subsystem=messaging-activemq/server=default/jms-topic=orders:add(
        entries=[
            "java:/topic/orders",
            "java:jboss/exported/topic/orders"
        ]
    )
end-if

stop-embedded-server
